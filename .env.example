# Copy this file to .env and fill in your values.
#
# The TopRep Supabase destination is fixed in the application code.
# You do NOT need to set TOPREP_API_URL or VITE_SUPABASE_URL — the app
# always sends data to the TopRep Supabase project.
#
# Fixed destination (baked into the app — do not override unless instructed):
# VITE_SUPABASE_URL=https://ahimfdfuuefesgbbnccr.supabase.co
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_SABMCFFXgDOvyvTvJWH0_w_qREoAIpS

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — without this token DealMaker cannot send data to Supabase.
# ─────────────────────────────────────────────────────────────────────────────
# User JWT issued by Supabase when you log in to the TopRep app.
# How to get it:
#   1. Log in to the TopRep app in your browser.
#   2. Open DevTools → Application tab → Local Storage → <app origin>.
#   3. Find the key starting with "sb-" (e.g. sb-ahimfdfuuefesgbbnccr-auth-token).
#   4. Copy the "access_token" value (starts with "eyJ…").
#   5. Paste it here (local dev) OR add it as a Vercel Environment Variable.
#
# SECURITY: never commit this token to source control.
# Tokens expire in ~1 hour; re-run the steps above to refresh.
TOPREP_AUTH_TOKEN=your-user-jwt

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — only needed for specific features
# ─────────────────────────────────────────────────────────────────────────────

# Phase 4 — Rep user provisioning (Admin Auth API)
# Required to enable "Provision Users" button on store detail page.
# NEVER commit or expose this key; it grants full admin access to your Supabase project.
# ⚠  NEVER add this as a Vercel Environment Variable — use it only in a local .env file.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL of the TopRep web app — used to generate direct QA login links in credential sheet.
# TOPREP_APP_URL=https://your-toprep-app.vercel.app

# Flask session secret (auto-generated at startup if not set; set explicitly in production)
# FLASK_SECRET_KEY=your-secret-key-here

# Safety override: allow provisioning against non-test email domains (NOT recommended)
# DEALMAKER_ALLOW_PROD_PROVISIONING=1
