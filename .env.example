# DealMaker — environment variables
# Copy this file to .env and fill in your values.
# The app will read .env automatically on startup.

# ── Flask session security ─────────────────────────────────────────────────
# A random secret used to sign browser sessions.  Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Required on Vercel (where each function instance gets a fresh random key
# by default, breaking sessions across requests).
FLASK_SECRET_KEY=

# ── Required for API delivery ──────────────────────────────────────────────
# Your TopRep user JWT (obtained from the TopRep app or fetch_supabase_jwt.ps1)
TOPREP_AUTH_TOKEN=

# ── Required for rep user provisioning ────────────────────────────────────
# Supabase service_role key — allows creating auth users via the Admin API.
# NEVER expose this to the browser or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional ───────────────────────────────────────────────────────────────
# Your deployed TopRep app URL — used to generate direct login links in the
# credentials table after provisioning (e.g. https://your-app.vercel.app)
TOPREP_APP_URL=

# Override the TopRep Supabase project URL (defaults to the TopRep project)
# TOPREP_API_URL=

# Postgres DSN — only needed if you want direct Postgres delivery
# DATABASE_URL=
