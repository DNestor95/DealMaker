# Copy this file to .env and fill in your values.
# Option A (preferred): TOP REP ingest API
TOPREP_API_URL=https://your-domain.com/api/events
TOPREP_AUTH_TOKEN=your-user-jwt

# Option B: direct Supabase REST insert into events table
# TOPREP_API_URL=https://your-project-ref.supabase.co
# TOPREP_AUTH_TOKEN=your-user-jwt
# SUPABASE_ANON_KEY=sb_publishable_xxx

# Option C: Supabase Edge Function URL
# TOPREP_API_URL=https://your-project-ref.supabase.co/functions/v1/your-function-name
# TOPREP_AUTH_TOKEN=your-user-jwt
# SUPABASE_ANON_KEY=sb_publishable_xxx
# Optional override (normally auto-derived from JWT sub):
# TOPREP_SALES_REP_ID=00000000-0000-0000-0000-000000000000

# Alternative Supabase variable names (compatible with Vite/frontend tooling conventions):
# These are recognised as fallbacks when TOPREP_API_URL / SUPABASE_ANON_KEY are not set.
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx

# Phase 4 — Rep user provisioning (Admin Auth API)
# Required to enable "Provision Users" button on store detail page.
# NEVER commit or expose this key; it grants full admin access to your Supabase project.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL of the TopRep web app — used to generate direct QA login links in credential sheet.
# TOPREP_APP_URL=https://your-toprep-app.vercel.app

# Flask session secret (auto-generated at startup if not set; set explicitly in production)
# FLASK_SECRET_KEY=your-secret-key-here

# Safety override: allow provisioning against non-test email domains (NOT recommended)
# DEALMAKER_ALLOW_PROD_PROVISIONING=1
