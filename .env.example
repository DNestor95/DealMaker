# Copy this file to .env and fill in your values.
# Option A (preferred): TOP REP ingest API
TOPREP_API_URL=https://your-domain.com/api/events
TOPREP_AUTH_TOKEN=your-user-jwt

# Option B: direct Supabase REST insert into events table
# TOPREP_API_URL=https://your-project-ref.supabase.co
# TOPREP_AUTH_TOKEN=your-user-jwt
# SUPABASE_ANON_KEY=sb_publishable_xxx

# Option C: Supabase Edge Function URL
# TOPREP_API_URL=https://your-project-ref.functions.supabase.co/your-function-name
# TOPREP_AUTH_TOKEN=your-user-jwt
# SUPABASE_ANON_KEY=sb_publishable_xxx
# Optional override (normally auto-derived from JWT sub):
# TOPREP_SALES_REP_ID=00000000-0000-0000-0000-000000000000
