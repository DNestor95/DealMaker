# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# ─── STEP 1: Get your auth token ────────────────────────────────────────────
#
# DealMaker sends data to the TopRep Supabase project using a user JWT.
# You need to obtain this token from your Supabase user account.
#
# Option A — Python helper (cross-platform, recommended):
#   python scripts/fetch_jwt.py
#   This prompts for your email and password, fetches the JWT, and writes
#   TOPREP_AUTH_TOKEN below automatically.
#
# Option B — PowerShell (Windows):
#   .\fetch_supabase_jwt.ps1
#   Same behaviour as Option A; requires SUPABASE_ANON_KEY set below.
#
# Option C — Manual (any platform):
#   POST https://ahimfdfuuefesgbbnccr.supabase.co/auth/v1/token?grant_type=password
#   Headers: apikey: sb_publishable_SABMCFFXgDOvyvTvJWH0_w_qREoAIpS
#            Content-Type: application/json
#   Body:    {"email":"you@example.com","password":"yourpassword"}
#   Copy the "access_token" from the response and paste it below.
#
# ─── STEP 2: Verify connectivity ────────────────────────────────────────────
#
# After setting TOPREP_AUTH_TOKEN, run:
#   python scripts/check_connection.py          # connectivity check
#   python scripts/check_connection.py --send   # check + send a test event
#
# ────────────────────────────────────────────────────────────────────────────

# Required: Supabase user JWT for authenticated API calls to TopRep.
# Obtain via: python scripts/fetch_jwt.py   (see STEP 1 above)
TOPREP_AUTH_TOKEN=your-user-jwt

# ─── Optional overrides ─────────────────────────────────────────────────────

# Override the default TopRep Supabase destination.
# Leave commented unless you are targeting a different project.
# Supported formats:
#   https://<ref>.supabase.co              → writes to /rest/v1/events
#   https://<ref>.supabase.co/api/events   → writes to /api/events
#   https://<ref>.functions.supabase.co/<fn> → edge function batch mode
# TOPREP_API_URL=https://ahimfdfuuefesgbbnccr.supabase.co

# Supabase publishable (anon) key.  Required when using fetch_supabase_jwt.ps1
# or when TOPREP_API_URL points to a non-default Supabase project.
# The default TopRep key is baked into the app; only set this to override it.
# SUPABASE_ANON_KEY=sb_publishable_...

# ─── Admin / provisioning (optional, server-only) ───────────────────────────

# SERVICE ROLE KEY — grants full admin access to your Supabase project.
# Required ONLY to enable the "Provision Users" button on the store detail page.
# NEVER commit this key. NEVER expose it to the browser or client-side code.
# Keep it server-side only (set in your deployment environment, not in source).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App links & Flask settings ─────────────────────────────────────────────

# URL of the TopRep web app — used to generate direct QA login links.
# TOPREP_APP_URL=https://your-toprep-app.vercel.app

# Flask session secret (auto-generated at startup if not set).
# Set explicitly in production deployments.
# FLASK_SECRET_KEY=your-secret-key-here

# Safety override: allow provisioning against non-test email domains (NOT recommended).
# DEALMAKER_ALLOW_PROD_PROVISIONING=1
